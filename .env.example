# ===== App =====
PORT=3000
NODE_ENV=production
# Timezone — must match where the PC/office is located (shift times are local)
TZ=Asia/Bangkok

# ===== HTTPS for LAN/Wi-Fi access (phones, tablets, other PCs) =====
# Browsers only allow the camera (getUserMedia) on localhost or HTTPS — a
# plain http://<server-ip>:3000 from another device on the network will NOT
# be able to use the camera. The server also listens on HTTPS_PORT with a
# self-signed certificate so other devices can reach it securely.
HTTPS_PORT=3443
# Set this to the server PC's LAN IP (run `ipconfig` on Windows, look for the
# IPv4 address on your Wi-Fi/Ethernet adapter, e.g. 192.168.1.50) so the cert
# covers it. Multiple IPs/hostnames: comma-separated. Required for phones/
# tablets to connect via https://<this-ip>:3443 without a certificate
# name-mismatch error. The first time each device visits, the browser will
# warn that the certificate isn't trusted (it's self-signed) — choose
# "Advanced" → "Proceed anyway" once; after that the camera works normally.
SERVER_LAN_IP=192.168.1.50

# ===== Database (MariaDB) =====
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=khd_attendance
DB_USER=khdapp
DB_PASSWORD=change_me_app_password
DB_ROOT_PASSWORD=change_me_root_password

# ===== Auth =====
# Generate a strong secret, e.g.: openssl rand -hex 32
JWT_SECRET=change_me_to_a_64_char_random_hex_string
JWT_EXPIRES_IN=8h

# ===== Face Recognition =====
# Lower = stricter match. face-api.js recommended default is 0.5 (euclidean distance).
# 0.45 gives some tolerance for descriptor drift (e.g. eyeglasses worn at scan
# time but not at enrollment) without being as loose as the 0.5 default.
FACE_MATCH_THRESHOLD=0.45
# Minimum distance gap required between the best and 2nd-best match (different
# employees) before trusting the result — guards against look-alike mismatches
FACE_MIN_MARGIN=0.08
# Ignore repeat scans of the same person within this many minutes
FACE_COOLDOWN_MINUTES=3
# Where captured face snapshots are stored (mapped to a Docker volume)
FACE_IMAGE_DIR=/data/faces

# ===== Branding =====
# Organisation name (shown on report headers)
COMPANY_NAME=สำนักงานสาธารณสุขจังหวัดนครราชสีมา
# System/app name (shown in navbar + login)
APP_NAME=ระบบลงเวลา KHD-FaceTo


# ===== Navicat ======
# Navicat Premium connection string for MariaDB (optional)
# NAVICAT_CONNECTION_STRING=khd-faceto (หรือชื่อใดก็ได้)
# Host=127.0.0.1 (หรือ localhost)
# Port=3307
# Database=khd_attendance
# User=khdapp
# Password=<DB_PASSWORD ของคุณ ดูในไฟล์ .env จริง — ห้ามใส่รหัสจริงในไฟล์ตัวอย่างนี้>
